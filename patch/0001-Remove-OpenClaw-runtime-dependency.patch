diff --git a/src/messaging/outbound-hooks.test.ts b/src/messaging/outbound-hooks.test.ts
new file mode 100644
index 0000000..9ffb016
--- /dev/null
+++ b/src/messaging/outbound-hooks.test.ts
@@ -0,0 +1,95 @@
+import { beforeEach, describe, expect, it, vi } from "vitest";
+
+vi.mock("../util/logger.js", () => ({
+  logger: {
+    warn: vi.fn(),
+  },
+}));
+
+import {
+  applyWeixinMessageSendingHook,
+  clearWeixinMessagingHooks,
+  emitWeixinMessageSent,
+  registerWeixinMessageSendingHook,
+  registerWeixinMessageSentListener,
+} from "./outbound-hooks.js";
+import { logger } from "../util/logger.js";
+
+beforeEach(() => {
+  clearWeixinMessagingHooks();
+  vi.clearAllMocks();
+});
+
+describe("applyWeixinMessageSendingHook", () => {
+  it("returns original text when no hooks are registered", async () => {
+    await expect(applyWeixinMessageSendingHook({ to: "u", text: "hello" })).resolves.toEqual({
+      cancelled: false,
+      text: "hello",
+    });
+  });
+
+  it("applies hooks sequentially and supports unsubscribe", async () => {
+    const unsubscribeFirst = registerWeixinMessageSendingHook(({ text }) => ({ text: `${text} a` }));
+    registerWeixinMessageSendingHook(async ({ text }) => ({ text: `${text} b` }));
+
+    await expect(applyWeixinMessageSendingHook({ to: "u", text: "hello" })).resolves.toEqual({
+      cancelled: false,
+      text: "hello a b",
+    });
+
+    unsubscribeFirst();
+    await expect(applyWeixinMessageSendingHook({ to: "u", text: "hello" })).resolves.toEqual({
+      cancelled: false,
+      text: "hello b",
+    });
+  });
+
+  it("cancels sending when a hook requests cancellation", async () => {
+    registerWeixinMessageSendingHook(({ text }) => ({ text: `${text} changed` }));
+    registerWeixinMessageSendingHook(() => ({ cancelled: true }));
+    registerWeixinMessageSendingHook(({ text }) => ({ text: `${text} never` }));
+
+    await expect(applyWeixinMessageSendingHook({ to: "u", text: "hello" })).resolves.toEqual({
+      cancelled: true,
+      text: "hello changed",
+    });
+  });
+
+  it("isolates hook errors and continues", async () => {
+    registerWeixinMessageSendingHook(() => {
+      throw new Error("boom");
+    });
+    registerWeixinMessageSendingHook(({ text }) => ({ text: `${text} ok` }));
+
+    await expect(applyWeixinMessageSendingHook({ to: "u", text: "hello" })).resolves.toEqual({
+      cancelled: false,
+      text: "hello ok",
+    });
+    expect(logger.warn).toHaveBeenCalledWith(expect.stringContaining("message_sending hook error"));
+  });
+});
+
+describe("emitWeixinMessageSent", () => {
+  it("notifies listeners and supports unsubscribe", async () => {
+    const listener = vi.fn();
+    const unsubscribe = registerWeixinMessageSentListener(listener);
+
+    emitWeixinMessageSent({ to: "u", content: "ok", success: true, accountId: "acc" });
+    await vi.waitFor(() => expect(listener).toHaveBeenCalledTimes(1));
+    expect(listener).toHaveBeenCalledWith({ to: "u", content: "ok", success: true, accountId: "acc" });
+
+    unsubscribe();
+    emitWeixinMessageSent({ to: "u", content: "ok", success: true });
+    await new Promise((resolve) => setTimeout(resolve, 0));
+    expect(listener).toHaveBeenCalledTimes(1);
+  });
+
+  it("isolates listener errors", async () => {
+    registerWeixinMessageSentListener(() => {
+      throw new Error("listener boom");
+    });
+
+    emitWeixinMessageSent({ to: "u", content: "bad", success: false, error: "x" });
+    await vi.waitFor(() => expect(logger.warn).toHaveBeenCalledWith(expect.stringContaining("message_sent listener failed")));
+  });
+});
