+++ b/src/standalone/openclaw-compat.test.ts
@@ -0,0 +1,141 @@
+import fs from "node:fs";
+import os from "node:os";
+import path from "node:path";
+
+import { afterEach, beforeEach, describe, expect, it } from "vitest";
+
+import {
+  createTypingCallbacks,
+  normalizeAccountId,
+  resolveDirectDmAuthorizationOutcome,
+  resolvePreferredOpenClawTmpDir,
+  resolveSenderCommandAuthorizationWithRuntime,
+  withFileLock,
+} from "./openclaw-compat.js";
+
+let tmpDir: string;
+
+beforeEach(() => {
+  tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), "openclaw-compat-test-"));
+});
+
+afterEach(() => {
+  delete process.env.OPENCLAW_TMP_DIR;
+  delete process.env.CLAWDBOT_TMP_DIR;
+  delete process.env.TMPDIR;
+  fs.rmSync(tmpDir, { recursive: true, force: true });
+});
+
+describe("normalizeAccountId", () => {
+  it("normalizes Weixin account IDs into stable filesystem-safe IDs", () => {
+    expect(normalizeAccountId(" ABC@IM.Bot ")).toBe("abc-im-bot");
+    expect(normalizeAccountId("a..b@@im.wechat")).toBe("a-b-im-wechat");
+  });
+
+  it("rejects IDs without valid characters", () => {
+    expect(() => normalizeAccountId(" 💬 ")).toThrow("accountId");
+  });
+});
+
+describe("resolvePreferredOpenClawTmpDir", () => {
+  it("uses OPENCLAW_TMP_DIR first", () => {
+    process.env.OPENCLAW_TMP_DIR = path.join(tmpDir, "openclaw-tmp");
+    process.env.CLAWDBOT_TMP_DIR = path.join(tmpDir, "clawdbot-tmp");
+    expect(resolvePreferredOpenClawTmpDir()).toBe(process.env.OPENCLAW_TMP_DIR);
+  });
+
+  it("uses CLAWDBOT_TMP_DIR then TMPDIR then os tmp fallback", () => {
+    process.env.CLAWDBOT_TMP_DIR = path.join(tmpDir, "clawdbot-tmp");
+    process.env.TMPDIR = path.join(tmpDir, "system-tmp");
+    expect(resolvePreferredOpenClawTmpDir()).toBe(process.env.CLAWDBOT_TMP_DIR);
+
+    delete process.env.CLAWDBOT_TMP_DIR;
+    expect(resolvePreferredOpenClawTmpDir()).toBe(process.env.TMPDIR);
+
+    delete process.env.TMPDIR;
+    expect(resolvePreferredOpenClawTmpDir()).toBe(path.join(os.tmpdir(), "openclaw"));
+  });
+});
+
+describe("withFileLock", () => {
+  it("serializes concurrent writers for the same file", async () => {
+    const target = path.join(tmpDir, "allowFrom.json");
+    const order: number[] = [];
+
+    await Promise.all([
+      withFileLock(target, { retries: { retries: 20, minTimeout: 1, maxTimeout: 5 }, stale: 10_000 }, async () => {
+        order.push(1);
+        await new Promise((resolve) => setTimeout(resolve, 10));
+        order.push(2);
+      }),
+      withFileLock(target, { retries: { retries: 20, minTimeout: 1, maxTimeout: 5 }, stale: 10_000 }, async () => {
+        order.push(3);
+      }),
+    ]);
+
+    const firstCriticalSection = order.indexOf(1) < order.indexOf(2);
+    const secondDidNotEnterMiddle = !(order.indexOf(3) > order.indexOf(1) && order.indexOf(3) < order.indexOf(2));
+    expect(firstCriticalSection).toBe(true);
+    expect(secondDidNotEnterMiddle).toBe(true);
+    expect(fs.existsSync(`${path.resolve(target)}.lock`)).toBe(false);
+  });
+
+  it("removes stale locks and continues", async () => {
+    const target = path.join(tmpDir, "stale.json");
+    const lockDir = `${path.resolve(target)}.lock`;
+    fs.mkdirSync(lockDir, { recursive: true });
+    const old = new Date(Date.now() - 60_000);
+    fs.utimesSync(lockDir, old, old);
+
+    const result = await withFileLock(target, { retries: { retries: 1, minTimeout: 1, maxTimeout: 1 }, stale: 1_000 }, async () => "ok");
+    expect(result).toBe("ok");
+    expect(fs.existsSync(lockDir)).toBe(false);
+  });
+
+  it("throws when a fresh lock cannot be acquired", async () => {
+    const target = path.join(tmpDir, "locked.json");
+    fs.mkdirSync(`${path.resolve(target)}.lock`, { recursive: true });
+
+    await expect(
+      withFileLock(target, { retries: { retries: 0, minTimeout: 1, maxTimeout: 1 }, stale: 60_000 }, async () => "never"),
+    ).rejects.toThrow("Timed out acquiring file lock");
+  });
+});
+
+describe("standalone auth helpers", () => {
+  it("authorizes commands when sender is allowed", async () => {
+    const result = await resolveSenderCommandAuthorizationWithRuntime({
+      rawBody: "/help",
+      senderId: "user1",
+      readAllowFromStore: async () => ["user1"],
+    });
+    expect(result).toEqual({ senderAllowedForCommands: true, commandAuthorized: true });
+    expect(resolveDirectDmAuthorizationOutcome(result)).toBe("authorized");
+  });
+
+  it("does not authorize commands for disallowed senders", async () => {
+    const result = await resolveSenderCommandAuthorizationWithRuntime({
+      rawBody: "/help",
+      senderId: "user2",
+      readAllowFromStore: async () => ["user1"],
+    });
+    expect(result).toEqual({ senderAllowedForCommands: false, commandAuthorized: false });
+    expect(resolveDirectDmAuthorizationOutcome(result)).toBe("unauthorized");
+  });
+
+  it("preserves typing callbacks", async () => {
+    let started = false;
+    let stopped = false;
+    const callbacks = createTypingCallbacks({
+      start: async () => { started = true; },
+      stop: async () => { stopped = true; },
+      keepaliveIntervalMs: 123,
+    });
+
+    await callbacks.start();
+    await callbacks.stop();
+    expect(started).toBe(true);
+    expect(stopped).toBe(true);
+    expect(callbacks.keepaliveIntervalMs).toBe(123);
+  });
+});
