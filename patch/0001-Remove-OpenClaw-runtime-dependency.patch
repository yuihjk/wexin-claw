index 0000000..04399c9
--- /dev/null
+++ b/src/standalone/openclaw-compat.ts
@@ -0,0 +1,206 @@
+import fs from "node:fs";
+import os from "node:os";
+import path from "node:path";
+
+export type OpenClawConfig = {
+  channels?: Record<string, unknown>;
+  session?: { store?: unknown };
+};
+
+export type ChannelAccountSnapshot = {
+  accountId: string;
+  lastEventAt?: number;
+  lastInboundAt?: number;
+  [key: string]: unknown;
+};
+
+export type ReplyPayload = {
+  text?: string;
+  mediaUrl?: string;
+  mediaUrls?: string[];
+};
+
+export type TypingCallbacks = {
+  start(): Promise<void>;
+  stop(): Promise<void>;
+  onStartError?(err: unknown): void;
+  onStopError?(err: unknown): void;
+  keepaliveIntervalMs?: number;
+};
+
+export type StandaloneChannelRuntime = {
+  media: {
+    saveMediaBuffer(
+      buffer: Buffer,
+      contentType?: string,
+      subdir?: string,
+      maxBytes?: number,
+      originalFilename?: string,
+    ): Promise<{ path: string }>;
+  };
+  commands?: unknown;
+  routing?: unknown;
+  session?: unknown;
+  reply?: unknown;
+};
+
+type FileLockRetryOptions = {
+  retries?: number;
+  factor?: number;
+  minTimeout?: number;
+  maxTimeout?: number;
+};
+
+export type FileLockOptions = {
+  retries?: FileLockRetryOptions;
+  stale?: number;
+};
+
+const DEFAULT_LOCK_RETRIES: Required<FileLockRetryOptions> = {
+  retries: 10,
+  factor: 1.6,
+  minTimeout: 25,
+  maxTimeout: 500,
+};
+
+const DEFAULT_STALE_MS = 30_000;
+
+function sanitizeAccountId(raw: string): string {
+  return raw
+    .trim()
+    .toLowerCase()
+    .replace(/@/g, "-")
+    .replace(/\./g, "-")
+    .replace(/[^a-z0-9_-]+/g, "-")
+    .replace(/-+/g, "-")
+    .replace(/^-|-$/g, "");
+}
+
+export function normalizeAccountId(id: string): string {
+  const normalized = sanitizeAccountId(id);
+  if (!normalized) {
+    throw new Error("accountId must contain at least one valid character");
+  }
+  return normalized;
+}
+
+export function resolvePreferredOpenClawTmpDir(): string {
+  return (
+    process.env.OPENCLAW_TMP_DIR?.trim() ||
+    process.env.CLAWDBOT_TMP_DIR?.trim() ||
+    process.env.TMPDIR?.trim() ||
+    path.join(os.tmpdir(), "openclaw")
+  );
+}
+
+function lockDirFor(filePath: string): string {
+  const resolved = path.resolve(filePath);
+  return `${resolved}.lock`;
+}
+
+function sleep(ms: number): Promise<void> {
+  return new Promise((resolve) => setTimeout(resolve, ms));
+}
+
+async function isStaleLock(lockDir: string, staleMs: number): Promise<boolean> {
+  try {
+    const stat = await fs.promises.stat(lockDir);
+    return Date.now() - stat.mtimeMs > staleMs;
+  } catch (err) {
+    if ((err as NodeJS.ErrnoException).code === "ENOENT") return false;
+    throw err;
+  }
+}
+
+async function removeLockDir(lockDir: string): Promise<void> {
+  try {
+    await fs.promises.rm(lockDir, { recursive: true, force: true });
+  } catch {
+    // Another process may have removed it first.
+  }
+}
+
+async function writeLockOwner(lockDir: string): Promise<void> {
+  const owner = {
+    pid: process.pid,
+    hostname: os.hostname(),
+    createdAt: new Date().toISOString(),
+  };
+  await fs.promises.writeFile(path.join(lockDir, "owner.json"), JSON.stringify(owner), "utf-8");
+}
+
+function nextDelayMs(attempt: number, retry: Required<FileLockRetryOptions>): number {
+  const exponential = retry.minTimeout * Math.pow(retry.factor, Math.max(0, attempt - 1));
+  const capped = Math.min(retry.maxTimeout, exponential);
+  const jitter = Math.random() * Math.min(50, capped * 0.2);
+  return Math.floor(capped + jitter);
+}
+
+async function acquireFileLock(filePath: string, options?: FileLockOptions): Promise<() => Promise<void>> {
+  const lockDir = lockDirFor(filePath);
+  const retry = { ...DEFAULT_LOCK_RETRIES, ...(options?.retries ?? {}) };
+  const staleMs = Math.max(options?.stale ?? DEFAULT_STALE_MS, 1_000);
+  await fs.promises.mkdir(path.dirname(lockDir), { recursive: true });
+
+  for (let attempt = 0; attempt <= retry.retries; attempt += 1) {
+    try {
+      await fs.promises.mkdir(lockDir);
+      await writeLockOwner(lockDir);
+      return async () => removeLockDir(lockDir);
+    } catch (err) {
+      if ((err as NodeJS.ErrnoException).code !== "EEXIST") throw err;
+
+      if (await isStaleLock(lockDir, staleMs)) {
+        await removeLockDir(lockDir);
+        continue;
+      }
+
+      if (attempt >= retry.retries) {
+        throw new Error(`Timed out acquiring file lock: ${lockDir}`);
+      }
+      await sleep(nextDelayMs(attempt + 1, retry));
+    }
+  }
+
+  throw new Error(`Timed out acquiring file lock: ${lockDir}`);
+}
+
+export async function withFileLock<T>(
+  filePath: string,
+  options: FileLockOptions | undefined,
+  fn: () => Promise<T>,
+): Promise<T> {
+  const release = await acquireFileLock(filePath, options);
+  try {
+    return await fn();
+  } finally {
+    await release();
+  }
+}
+
+export function createTypingCallbacks(callbacks: TypingCallbacks): TypingCallbacks {
+  return callbacks;
+}
+
+export async function resolveSenderCommandAuthorizationWithRuntime(params: {
+  rawBody: string;
+  senderId: string;
+  readAllowFromStore?: () => Promise<string[]>;
+  isSenderAllowed?: (id: string, list: string[]) => boolean;
+}): Promise<{ senderAllowedForCommands: boolean; commandAuthorized: boolean }> {
+  const allowFrom = await params.readAllowFromStore?.() ?? [];
+  const isAllowed = params.isSenderAllowed
+    ? params.isSenderAllowed(params.senderId, allowFrom)
+    : allowFrom.length === 0 || allowFrom.includes(params.senderId);
+  const isCommand = params.rawBody.trim().startsWith("/");
+  return {
+    senderAllowedForCommands: isAllowed,
+    commandAuthorized: isCommand && isAllowed,
+  };
+}
+
+export function resolveDirectDmAuthorizationOutcome(params: {
+  senderAllowedForCommands: boolean;
+}): "authorized" | "unauthorized" {
+  return params.senderAllowedForCommands ? "authorized" : "unauthorized";
+}
